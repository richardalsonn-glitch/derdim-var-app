{
  "expo": {
    "name": "Derdim Var",
    "slug": "derdim-var-app",
    "version": "1.0.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#060816"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Derdim Var sesli anonim görüşmeler için mikrofon erişimine ihtiyaç duyar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#060816"
      },
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Derdim Var sesli anonim görüşmeler için mikrofon erişimine ihtiyaç duyar.",
          "recordAudioAndroid": true
        }
      ]
    ]
  }
}
